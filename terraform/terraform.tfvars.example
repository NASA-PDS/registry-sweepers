nodes = {
  "en" = { cpu = 1024, memory = 4096 },
  "geo" = { cpu = 1024, memory = 4096 },
  "atm" = { cpu = 1024, memory = 4096 },
  "ppi" = { cpu = 1024, memory = 4096 },
  "img" = { cpu = 1024, memory = 4096 },
  "naif" = { cpu = 1024, memory = 4096 },
  "psa" = { cpu = 1024, memory = 4096 },
  "rms" = { cpu = 1024, memory = 4096 },
  "sbnpsi" = { cpu = 1024, memory = 4096 },
  "sbnumd" = { cpu = 1024, memory = 4096 }
}
