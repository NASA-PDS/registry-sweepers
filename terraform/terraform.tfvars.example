venue              = "prod"
aoss_endpoint      = "https://..."
aoss_collection_id = "..."
image_uri          = "123456789012.dkr.ecr.us-west-2.amazonaws.com/pds-registry-sweepers:latest"

permissions_boundary_policy_name = "mcp-tenantOperator-APIG"

mwaa_execution_role_name=<role name used by Airflow for DAG execution>

# ECS resource allocations for each node
