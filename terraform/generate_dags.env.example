# Constants shared across all nodes — not tracked in git.
# See generate_dags.env.example for documentation.

ECS_CLUSTER_NAME=pds-nucleus-ecs
ECS_SUBNETS=[<the private subnets where the ECS task run>]
ECS_SECURITY_GROUPS=["sg-<you security group id>"]

# Venue name used in log group paths
VENUE=pds-en-dev

# Directory where DAG files are written (default: repo root)
DAGS_OUTPUT_DIR=./dags/
